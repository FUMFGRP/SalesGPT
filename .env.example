# Sky Cloud - SalesGPT Configuration
# Copy this to .env and fill in your actual API keys

# ===============================
# LLM CONFIGURATION (Required)
# ===============================

# Option 1: OpenAI Direct
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: OpenRouter (Recommended - access multiple models)
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model Selection
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For OpenRouter: openai/gpt-4, openai/gpt-3.5-turbo, anthropic/claude-3-opus, etc.
GPT_MODEL=openai/gpt-4

# Optional: Other LLM providers via LiteLLM
# ANTHROPIC_API_KEY=sk-ant-...
# HUGGINGFACE_API_KEY=hf_...

# ===============================
# COMPOSIO AUTH & TOOLS (Required for enhanced agent capabilities)
# Get your API key from: https://app.composio.dev
# ===============================
COMPOSIO_API_KEY=ak_Qpc0UWPcoDX8XSPy-zqK
COMPOSIO_APP_NAME=resend,googlecalendar,gmail
# Optional: Specific app integrations via Composio
# COMPOSIO_ENTITY_ID=default
# COMPOSIO_BASE_URL=https://backend.composio.dev

# ===============================
# RESEND EMAIL (via Composio or Direct)
# For sending transactional emails
# Get API key from: https://resend.com/api-keys
# ===============================
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=info@aurasky.cloud
RESEND_FROM_NAME="Aura from Aura Sky Cloud"

# ===============================
# AGENT CONFIGURATION
# ===============================
USE_TOOLS_IN_API=True
CONFIG_PATH=aura_config/aura_agent_setup.json
PRODUCT_CATALOG=aura_config/aura_products.txt

# ===============================
# PAYMENT INTEGRATION (Optional)
# ===============================
# For Stripe payment link generation
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_GATEWAY_URL=https://your-payment-gateway.vercel.app/payment

# Product price mapping for Stripe
PRODUCT_PRICE_MAPPING=aura_config/price_mapping.json

# ===============================
# CALENDAR INTEGRATION (Optional)
# ===============================
# For Calendly meeting scheduling
CALENDLY_API_KEY=your-calendly-api-key
CALENDLY_EVENT_UUID=your-event-uuid

# ===============================
# EMAIL INTEGRATION (Optional)
# ===============================
# For automated email sending
GMAIL_APP_PASSWORD=your-gmail-app-password
GMAIL_MAIL=your-email@gmail.com

# ===============================
# API & FRONTEND SETTINGS
# ===============================
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development

# For production deployment:
# NEXT_PUBLIC_API_URL=https://your-api-domain.com
# NEXT_PUBLIC_ENVIRONMENT=production

# ===============================
# MONITORING & LOGGING
# ===============================
# Optional: Enable detailed logging
VERBOSE=True
LOG_LEVEL=INFO

# ===============================
# QUICK START CHECKLIST
# ===============================
# Required for basic bot:
# ✓ OPENAI_API_KEY
# ✓ TWILIO_ACCOUNT_SID
# ✓ TWILIO_AUTH_TOKEN  
# ✓ TWILIO_PHONE_NUMBER
#
# Optional but recommended:
# ☐ COMPOSIO_API_KEY (for auth & tool integration)
#
# Optional integrations:
# ☐ STRIPE_API_KEY (for payments)
# ☐ CALENDLY_API_KEY (for scheduling)
# ☐ GMAIL_APP_PASSWORD (for email)
